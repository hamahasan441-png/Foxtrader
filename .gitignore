# ============================================================================
# FOXTRADER — Git ignore
# ============================================================================

# Android / Gradle
*.iml
.gradle/
/local.properties
/.idea/
.DS_Store
/build
/app/build
/captures
.externalNativeBuild
.cxx
local.properties

# Kotlin
*.kotlin_module

# Keystore (never commit signing keys)
*.jks
*.keystore
!debug.keystore

# Backend (Python)
backend/__pycache__/
backend/**/__pycache__/
backend/.venv/
backend/*.pyc
backend/.env

# Reference (TypeScript porting source — not built)
reference/**/node_modules/
reference/**/dist/

# OS
Thumbs.db
